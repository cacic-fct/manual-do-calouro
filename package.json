{
  "name": "manual-do-calouro",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "dev": "docusaurus start --no-open",
    "start": "docusaurus start",
    "build:analytics": "mkdir -p static/js && bun build src/analytics/cacic-umami-tracking.ts --target=browser --format=iife --outfile=static/js/cacic-umami-tracking.js --minify",
    "build": "bun run build:analytics && docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "bun run build:analytics && docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@cacic-fct/account-manager-cookie-banner": "^0.0.1",
    "@cacic-fct/account-manager-privacy": "0.0.2",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "docusaurus-theme-search-typesense": "^0.26.0",
    "lucide-react": "^1.14.0",
    "ol": "^10.9.0",
    "postcss": "^8.5.14",
    "postcss-cli": "^11.0.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-vertical-timeline-component": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "typesense-docsearch-react": "^3.4.1",
    "unleash-proxy-client": "^3.8.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "typescript": "~6.0.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
